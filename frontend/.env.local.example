# Backend URL for the Next.js proxy rewrite (server-side only).
# The proxy in next.config.mjs rewrites /api/v1/* → BACKEND_URL/v1/*
BACKEND_URL=http://127.0.0.1:8000

# Do NOT set NEXT_PUBLIC_API_URL unless you have CORS configured on the backend.
# By default, API calls route through the Next.js proxy to avoid CORS issues.
# NEXT_PUBLIC_API_URL=/api/v1
